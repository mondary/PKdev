#!/bin/bash
# ============================================================
#  devpi — Lanceur du workspace (layout VSCode dans Kaku)
# ============================================================

DIR="$(cd "$(dirname "$0")" && pwd)"
KAKU="/Applications/Kaku.app/Contents/MacOS/kaku"
KANBAN="$DIR/kanban/target/release/kanban"

# Vérifier que le kanban est compilé
if [ ! -f "$KANBAN" ]; then
  echo "Compilation du Kanban..."
  (cd "$DIR/kanban" && cargo build --release) || exit 1
fi

# Fermer les instances précédentes de ce workspace
pkill -f "workspace.lua" 2>/dev/null
sleep 1

# Lancer Kaku avec la config du projet
exec "$KAKU" \
  --config-file "$DIR/kaku/workspace.lua" \
  start --always-new-process --cwd "$DIR"
